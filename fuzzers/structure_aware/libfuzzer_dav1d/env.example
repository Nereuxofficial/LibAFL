# Docker Compose Environment Configuration for LibAFL dav1d Fuzzer
# Copy this file to .env and adjust values as needed

# Resource Limits
# Maximum CPU cores available to the fuzzer (default: 4)
CPU_LIMIT=4
# Minimum CPU cores reserved for the fuzzer (default: 2)
CPU_RESERVATION=2
# Maximum memory available to the fuzzer (default: 4G)
MEMORY_LIMIT=4G
# Minimum memory reserved for the fuzzer (default: 2G)
MEMORY_RESERVATION=2G

# Logging Configuration
# Rust log level: trace, debug, info, warn, error (default: info)
RUST_LOG=info
# Enable Rust backtraces: 0, 1, full (default: 1)
RUST_BACKTRACE=1

# User/Group IDs (for fixing permission issues)
# Uncomment and set to your user/group IDs if you encounter permission issues
# UID=1000
# GID=1000

# Container Configuration
# Container restart policy: no, always, on-failure, unless-stopped (default: unless-stopped)
RESTART_POLICY=unless-stopped

# Fuzzer Options
# Number of fuzzer instances/cores to use (passed as argument to fuzzer if supported)
# FUZZER_CORES=4

# Timeout for individual test cases in milliseconds (if supported by fuzzer)
# TIMEOUT_MS=1000

# Additional fuzzer arguments (space-separated)
# FUZZER_ARGS=""

# Output Directories (relative to docker-compose.yml location)
# Standard mode
CRASHES_DIR=./crashes
CORPUS_OUTPUT_DIR=./corpus_output
SOLUTIONS_DIR=./solutions

# Concolic mode
CRASHES_CONCOLIC_DIR=./crashes_concolic
CORPUS_CONCOLIC_DIR=./corpus_concolic
SOLUTIONS_CONCOLIC_DIR=./solutions_concolic

# Build Configuration
# Docker build arguments
# BUILDKIT_PROGRESS=plain  # Use 'plain' for detailed build output
